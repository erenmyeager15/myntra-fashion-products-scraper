{
  "actorSpecification": 1,
  "name": "myntra-fashion-products-scraper",
  "title": "Myntra Fashion Products Scraper - Catalog & Price Data",
  "description": "Scrape public Myntra fashion product search/category results with titles, brands, prices, MRP, discounts, ratings, sizes, categories, image URLs, and product URLs.",
  "version": "1.0",
  "categories": ["ECOMMERCE", "OTHER"],
  "categoriesVersion": "1.0.0",
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "output": "./output_schema.json",
  "storages": {
    "dataset": "./dataset_schema.json"
  },
  "exampleRunInput": {
    "body": "{\"searchQueries\":[\"tshirts\"],\"categoryPaths\":[],\"maxResults\":1,\"sortBy\":\"recommended\",\"proxyConfiguration\":{\"useApifyProxy\":true,\"apifyProxyGroups\":[\"RESIDENTIAL\"],\"apifyProxyCountry\":\"IN\"}}",
    "contentType": "application/json; charset=utf-8"
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts running. Number of events charged depends on Actor memory (one event per GB, minimum one event).",
          "eventPriceUsd": 0.00005,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "product-scraped": {
          "eventTitle": "Product scraped",
          "eventDescription": "Charged once for each clean Myntra product record saved to the dataset.",
          "eventPriceUsd": 0.002,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 512,
    "timeoutSecs": 3600
  },
  "minMemoryMbytes": 256,
  "maxMemoryMbytes": 2048
}
