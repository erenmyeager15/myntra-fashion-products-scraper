{
  "actorSpecification": 1,
  "name": "myntra-fashion-products-scraper",
  "title": "Myntra Fashion Products Scraper - Catalog & Price Data",
  "description": "Scrape public Myntra fashion product search/category results: brand, title, price, MRP, discount, rating, reviews, sizes, color, image, and product URL.",
  "version": "1.0",
  "categories": ["ECOMMERCE", "LEAD_GENERATION", "OTHER"],
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "products": {
          "title": "Products",
          "transformation": {
            "fields": ["imageUrl", "searchQuery", "categoryPath", "position", "productId", "brand", "title", "additionalInfo", "gender", "category", "primaryColour", "price", "priceDisplay", "mrp", "mrpDisplay", "discountAmount", "discountPercent", "discountDisplayLabel", "rating", "ratingCount", "sizes", "productUrl", "scrapedAt"]
          },
          "display": {
            "component": "table",
            "properties": {
              "imageUrl": { "label": "Image", "format": "image" },
              "searchQuery": { "label": "Search", "format": "text" },
              "categoryPath": { "label": "Category Path", "format": "text" },
              "position": { "label": "Position", "format": "number" },
              "productId": { "label": "Product ID", "format": "number" },
              "brand": { "label": "Brand", "format": "text" },
              "title": { "label": "Product", "format": "text" },
              "additionalInfo": { "label": "Info", "format": "text" },
              "gender": { "label": "Gender", "format": "text" },
              "category": { "label": "Category", "format": "text" },
              "primaryColour": { "label": "Color", "format": "text" },
              "price": { "label": "Price", "format": "number" },
              "priceDisplay": { "label": "Price Text", "format": "text" },
              "mrp": { "label": "MRP", "format": "number" },
              "mrpDisplay": { "label": "MRP Text", "format": "text" },
              "discountAmount": { "label": "Discount Amount", "format": "number" },
              "discountPercent": { "label": "Discount %", "format": "number" },
              "discountDisplayLabel": { "label": "Discount Label", "format": "text" },
              "rating": { "label": "Rating", "format": "number" },
              "ratingCount": { "label": "Ratings", "format": "number" },
              "sizes": { "label": "Sizes", "format": "array" },
              "productUrl": { "label": "URL", "format": "link" },
              "scrapedAt": { "label": "Scraped At", "format": "date" }
            }
          }
        }
      }
    }
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "reasonForChange": "Initial pay-per-event pricing for clean Myntra fashion product records.",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "product-scraped": {
          "eventTitle": "Product scraped",
          "eventDescription": "Charged once for each clean Myntra product record saved to the dataset.",
          "eventPriceUsd": 0.002
        }
      }
    }
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 512,
    "timeoutSecs": 3600
  },
  "minMemoryMbytes": 256,
  "maxMemoryMbytes": 2048
}
